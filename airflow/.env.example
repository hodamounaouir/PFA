# Variables pour docker compose (Airflow). Optionnel : copier en .env dans CE dossier.
#   cp .env.example .env
#
# Sous Windows, laisse AIRFLOW_UID=50000 : Docker Desktop gère les permissions.
# (Sous Linux, mets ton uid réel : echo "AIRFLOW_UID=$(id -u)" > .env)
#
# NB : les identifiants Snowflake ne sont PAS ici — ils sont dans le .env À LA
# RACINE du repo (../.env), lu par le pipeline et par dbt.
AIRFLOW_UID=50000
