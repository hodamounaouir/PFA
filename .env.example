# Copier vers .env (cp .env.example .env) puis renseigner les valeurs.
# .env est ignoré par git — ne JAMAIS commiter de vraie clé.

# --- Snowflake (phase 0.2, ADR 001) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=

# --- LLM (Groq, gratuit) ---
GROQ_API_KEY=

# --- Dataset Olist : téléchargement manuel (pas de clé API nécessaire) ---
# https://www.kaggle.com/datasets/olistbr/brazilian-ecommerce
# → dézipper les CSV dans data/olist/ (dossier gitignoré)
